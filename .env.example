# Copy to server/.env for local development

NODE_ENV="development"
# Local Docker Postgres (docker compose up -d postgres). Do NOT point local
# development at a remote Render DB — high latency causes dashboard/approval 500s.
DATABASE_URL="postgresql://kitchenos:kitchenos@localhost:5432/kitchenos?schema=public&connection_limit=10&pool_timeout=20"
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="1d"
JWT_REMEMBER_EXPIRES_IN="30d"
PORT=4000
CLIENT_URL="http://localhost:5173"
PUBLIC_APP_URL="http://localhost:5173"
# Hours until approval activation links expire (default 24)
ACTIVATION_TOKEN_HOURS=24
# Production: Render API origin (absolute media URLs in JSON)
# PUBLIC_API_URL="https://saas-restaurant-menu.onrender.com"
UPLOAD_DIR="uploads"
# Local mail catcher: docker compose up -d mailpit → http://localhost:8025
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="KitchenOS <noreply@kitchenos.local>"
ADMIN_EMAIL="admin@kitchenos.local"
ADMIN_PASSWORD="Admin@12345"
ADMIN_NAME="KitchenOS Admin"
STAFF_ADMIN_EMAIL="staff@kitchenos.local"
STAFF_ADMIN_PASSWORD="Staff@12345"
STAFF_ADMIN_NAME="KitchenOS Staff"
SUBSCRIPTION_ALERTS_INTERVAL_MINUTES=60
BACKUP_DIR="backups"
BACKUP_RETAIN_DAYS=14
BACKUP_INTERVAL_HOURS=24
# Minimum length for newly created/changed passwords (floor 8; raise e.g. to 12 later)
PASSWORD_MIN_LENGTH=8
# Optional Redis for distributed API caching (multi-instance). Without it, in-memory cache is used.
# REDIS_URL="redis://localhost:6379"
