{
  "name": "saas-restaurant-menu",
  "version": "1.0.0",
  "private": true,
  "description": "KitchenOS — QR Restaurant Menu SaaS",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w server && npm run build -w client",
    "start": "npm run start -w server",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "npm run db:generate -w server",
    "db:migrate": "npm run db:migrate -w server",
    "db:migrate:deploy": "npm run db:migrate:deploy -w server",
    "db:seed": "npm run db:seed -w server",
    "db:studio": "npm run db:studio -w server"
  },
  "engines": {
    "node": ">=20"
  }
}
