# Production build template.
# Copy to `.env.production` for local `vite build`, AND set the same keys
# in Vercel → Project → Settings → Environment Variables (Production).
#
# VITE_* values are baked into the JS bundle at build time.

# Your Render API origin — HTTPS, NO trailing slash, NO /api/v1
# Example: https://kitchenos-api.onrender.com
VITE_API_URL=https://YOUR-API.onrender.com

VITE_SESSION_IDLE_MS=180000
VITE_SESSION_WARNING_MS=30000
