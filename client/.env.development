# Local development — used by `npm run dev` (Vite mode: development).
# Leave VITE_API_URL empty so the Vite proxy forwards /api and /uploads
# to http://localhost:4000 (see client/vite.config.ts).

VITE_API_URL=

# Session idle timeout (ms)
# Tenant portal: 3 minutes inactivity, 30s warning
VITE_SESSION_IDLE_MS=180000
VITE_SESSION_WARNING_MS=30000
# Admin panel: 5 minutes inactivity, 30s warning
VITE_ADMIN_SESSION_IDLE_MS=300000
VITE_ADMIN_SESSION_WARNING_MS=30000
