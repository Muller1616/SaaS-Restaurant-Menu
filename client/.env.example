# =============================================================================
# KitchenOS client — environment variables
# =============================================================================
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
#
# Local development:
#   - Use `.env.development` (already in repo) OR copy this file to `.env`
#   - Keep VITE_API_URL empty → Vite proxies /api and /uploads to :4000
#
# Production (Vercel):
#   1. Copy `.env.production.example` → set VITE_API_URL to your Render API
#   2. In Vercel → Settings → Environment Variables, set the SAME keys
#      for Production (required — Vercel builds do not use your laptop files)
#   3. Redeploy after changing any VITE_* value
#
# Frontend live URL (for Render CLIENT_URL / PUBLIC_APP_URL):
#   https://saa-s-restaurant-menu-client.vercel.app
# =============================================================================

# Render API origin only. No trailing slash. No /api/v1 suffix.
# Local: leave empty
# Production example: https://kitchenos-api.onrender.com
VITE_API_URL=

# Idle session timeout (milliseconds)
# Tenant portal defaults
VITE_SESSION_IDLE_MS=180000
VITE_SESSION_WARNING_MS=30000
# Admin panel (5 minutes inactivity)
VITE_ADMIN_SESSION_IDLE_MS=300000
VITE_ADMIN_SESSION_WARNING_MS=30000

# Must match server PASSWORD_MIN_LENGTH (minimum 8)
VITE_PASSWORD_MIN_LENGTH=8
