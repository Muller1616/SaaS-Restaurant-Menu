# Copy to client/.env.local for local overrides (optional)

# Production (Vercel): your Render API origin — no trailing slash
# Example: https://kitchenos-api.onrender.com
# Leave empty locally so Vite proxies /api and /uploads to the server.
VITE_API_URL=

# Idle session timeout (ms). Default: 3 minutes idle, 30s warning.
VITE_SESSION_IDLE_MS=180000
VITE_SESSION_WARNING_MS=30000
